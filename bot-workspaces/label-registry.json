    "bot:slack-triage": {
      "workspace": "slack-triage/",
      "entry_stage": "1-fetch-and-classify",
      "trigger": "cron",
      "model": "sonnet"
    },
    "bot:github-respond": {
      "workspace": "github-respond/",
      "entry_stage": "respond",
      "trigger": "webhook",
      "effort": "max"
    },
