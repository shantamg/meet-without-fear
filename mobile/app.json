{
  "expo": {
    "name": "Meet Without Fear",
    "slug": "meet-without-fear",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meetwithoutfear",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.galuten.meetwithoutfear",
      "buildNumber": "35",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to record audio sessions."
      },
      "appleTeamId": "446P429C8Q",
      "associatedDomains": [
        "applinks:meetwithoutfear.com"
      ],
      "splash": {
        "image": "./assets/images/icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0f172a"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "icon": "./assets/images/icon.png",
      "package": "com.meetwithoutfear.app",
      "versionCode": 34,
      "permissions": [
        "RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "meetwithoutfear.com",
              "pathPrefix": "/invitation"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f172a"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f381a744-a85d-478c-a8dd-75d54414aa5a"
      },
      "router": {
        "root": "./app"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f381a744-a85d-478c-a8dd-75d54414aa5a",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": "1.0.0",
    "experiments": {
      "typedRoutes": true
    },
    "owner": "shantamg"
  }
}
